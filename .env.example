# ═══════════════════════════════════════════════════
# CrisisBridge AI — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this to .env and fill in real values
# cp .env.example .env
# ═══════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
APP_NAME=CrisisBridge AI
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ── Auth (JWT) ───────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database (PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crisisbridge
DB_ECHO=False

# ── Redis ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300

# ── FAISS / Embeddings ──────────────────────────
FAISS_INDEX_PATH=data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ── LLM ─────────────────────────────────────────
LLM_MODEL=gpt-3.5-turbo
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── Session ──────────────────────────────────────
SESSION_MEMORY_SIZE=5

# ── Safety ───────────────────────────────────────
SAFETY_RADIUS_WARNING_METERS=100.0
SAFETY_RADIUS_EVACUATE_METERS=50.0

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/crisisbridge.log

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
